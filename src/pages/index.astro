---
// @ts-nocheck
import BaseLayout from '../layouts/BaseLayout.astro'
import ProjectComponent from '../components/ProjectComponent.astro'
---

<BaseLayout title="I'm Jean-Carlos" Herotext="I'm" HeroTextBottom="Jean-Carlos" 
	HeroStory="Emerging student designer based in Amsterdam
	with a passion for creating innovative and 
	aesthetically pleasing digital
	products.">


	<section id="intro-message">
		<p>I design digital experiences, including <span>websites</span>, <span>apps</span>, and <span>interfaces</span> that delight your customers and help create stronger engagement and brand loyalty.</p>
	</section>

	
	<ProjectComponent projectType="Front end development project" title="AT5" 
	description="AT5 is Amsterdam's city broadcaster for local news and 
	events via TV, radio, and online." 
	imageUrl="/images/at5.webp" 
	
	projectType2="Front end development project" title2="AT5" 
	description2="AT5 is Amsterdam's city broadcaster for local news and 
	events via TV, radio, and online." 
	imageUrl2="/images/at5.webp"
	/>

	<ProjectComponent projectType="Front end development project" title="AT5" 
	description="AT5 is Amsterdam's city broadcaster for local news and 
	events via TV, radio, and online." 
	imageUrl="/images/at5.webp"

	projectType2="Front end development project" title2="AT5" 
	description2="AT5 is Amsterdam's city broadcaster for local news and 
	events via TV, radio, and online." 
	imageUrl2="/images/at5.webp"
	/>

	<section id="scroll-container">
		<div class="scroll-scene">
			<div class="scroll-text">
				<h2>view my <br> favorite projects</h2>
				<p>Welcome to the overview of my favorite projects! Here, you’ll get a glimpse of the work I’m most proud of. These projects reflect my passion, skills, and commitment to quality.</p>
				<a href="/projecten">Explore all Projects</a>
			</div>

			<div class="image-group">
				<img src="/images/at5.webp" alt="">
				<img src="/images/at5.webp" alt="">
				<img src="/images/at5.webp" alt="">
				<img src="/images/at5.webp" alt="">
				<img src="/images/at5.webp" alt="">
				<img src="/images/at5.webp" alt="">
				<img src="/images/at5.webp" alt="">
				<img src="/images/at5.webp" alt="">
			</div>
		</div>
	</section>
	

</BaseLayout>

<style>
	#intro-message {
		font-size: clamp(1.5rem, 5vw, 7rem);
		font-family: var(--font-primary);
		width: 90%;

		span {
			color: var(--accent-color);
		}
			
	}

	#scroll-container {
		min-height: 200vh;
    	position: relative;
		view-timeline-name: --favorite-projects;
		view-timeline-axis: block;
	}

	.scroll-scene {
		position: sticky;
		top: 50vh;
		min-height: 32rem;
		display: grid;
		place-items: center;
		transform: translateY(-50%);
	}

	.scroll-text {
		grid-area: 1 / 1;
		z-index: 1;
		max-width: 45rem;
		text-align: center;
		opacity: 0;
		animation: text-appear linear forwards;
		animation-timeline: --favorite-projects;
		animation-range: entry 99% cover 50%;
	}

	.scroll-text h2 {
		font-family: var(--font-primary);
		font-size: var(--font-size-h2);
	}

	.scroll-text p {
		margin: 1rem 0;
		font-family: var(--secondairy-font);
		font-size: var(--text-size);
		line-height: 1.5;
	}

	.scroll-text a {
		color: var(--secondary-color);
		font-family: var(--font-primary);
		font-size: var(--font-size-h3);
		text-decoration: none;
	}

	.image-group {
		grid-area: 1 / 1;
		z-index: 0;
		display: grid;
		place-items: center;
	}

	.image-group img {
		grid-area: 1 / 1;
		width: clamp(12rem, 35vw, 32rem);
		aspect-ratio: 16 / 10;
		object-fit: cover;
		border-radius: 10px;
		animation: image-away linear forwards;
		animation-timeline: --favorite-projects;
		animation-range: entry 70% cover 55%;
	}

	@keyframes image-away {
		to {
			transform: translate(var(--x, 0), var(--y, -8rem)) rotate(var(--r, 0deg)) scale(0.5);
		}
	}

	@keyframes text-appear {
		to {
			opacity: 1;
		}
	}

	.image-group img:nth-child(1) {
		--x: clamp(-28rem, -32vw, -12rem);
		--y: clamp(-14rem, -16vw, -7rem);
	}

	.image-group img:nth-child(2) {
		--x: clamp(2rem, 5vw, 8rem);
		--y: clamp(-20rem, -24vw, -10rem);
	}

	.image-group img:nth-child(3) {
		--x: clamp(6rem, 45vw, 26rem);
		--y: clamp(-16rem, -18vw, -8rem);
	}

	.image-group img:nth-child(4) {
		--x: clamp(15rem, 34vw, 32rem);
		--y: clamp(1rem, 3vw, 4rem);
	}

	.image-group img:nth-child(5) {
		--x: clamp(16rem, 32vw, 30rem);
		--y: clamp(11rem, 18vw, 18rem);
	}

	.image-group img:nth-child(6) {
		--x: clamp(8rem, 13vw, 14rem);
		--y: clamp(15rem, 23vw, 21rem);
	}

	.image-group img:nth-child(7) {
		--x: clamp(-25rem, -30vw, -12rem);
		--y: clamp(13rem, 21vw, 19rem);
	}

	.image-group img:nth-child(8) {
		--x: clamp(-32rem, -38vw, -15rem);
		--y: clamp(2rem, 5vw, 7rem);
	}



</style>
